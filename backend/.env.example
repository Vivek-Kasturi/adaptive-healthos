# Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# MongoDB
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/healthos
MONGODB_DB_NAME=healthos

# App
APP_ENV=development
SECRET_KEY=replace-with-random-32-char-secret-key
